# Forge Picks — TxLINE config. Copy to .env and fill the two tokens.
# App runs fully in MOCK mode until both TXLINE_GUEST_JWT and TXLINE_API_TOKEN are set.

# mainnet = realtime (service level 12) · devnet = testing
TXLINE_NETWORK=mainnet
# Optional explicit override (else derived from TXLINE_NETWORK):
#   mainnet -> https://txline.txodds.com/api
#   devnet  -> https://txline-dev.txodds.com/api
# TXLINE_BASE_URL=

# From the auth flow — see scripts/txline-activate.md
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=

# Optional: restrict fixtures to one competition (World Cup id from the WC docs).
# Leave blank to return everything your subscription grants (WC + Int Friendlies).
TXLINE_COMPETITION_ID=

API_PORT=8787
